rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Safety verification check to restrict malicious document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Products Catalog
    match /products/{productId} {
      allow get, list: if true;
      allow write: if isValidId(productId);
    }

    // 2. Orders Ledger
    match /orders/{orderId} {
      allow get: if isValidId(orderId);
      allow list: if true;
      allow write: if isValidId(orderId);
    }

    // 3. Shop & Delivery Settings
    match /settings/{settingsId} {
      allow get, list: if true;
      allow write: if isValidId(settingsId);
    }
  }
}
